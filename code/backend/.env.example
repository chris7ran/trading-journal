# Copy to .env (local dev) or use as a systemd EnvironmentFile (production).
# NEVER commit the real .env — it is git-ignored.

# --- Required secrets ---------------------------------------------------------
# Random 32+ byte secret used to sign JWTs. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Argon2 PHC hash of your login password. Generate it with:
#   cargo run --release -- hash 'your-password-here'
# Then paste the printed hash below (keep the single quotes).
ADMIN_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$...replace-me...'

# --- Optional (defaults shown) ------------------------------------------------
# SQLite connection string. The file is created automatically if missing.
DATABASE_URL=sqlite://data/journal.db

# Address the server binds to.
BIND_ADDR=0.0.0.0:8080

# JWT lifetime in hours (default 168 = 7 days).
JWT_TTL_HOURS=168

# CORS: '*' for any origin, or a comma-separated list, e.g.
#   CORS_ALLOWED_ORIGINS=http://localhost:8081,https://journal.example.ts.net
CORS_ALLOWED_ORIGINS=*

# Log verbosity (optional).
RUST_LOG=info,tower_http=info,sqlx=warn

# --- Optional external data ---------------------------------------------------
# FRED API key (free: https://fredaccount.stlouisfed.org/apikeys) — enables the
# monthly US indicators + real Fed Funds rate in the macro tab. Leave empty to
# skip those cards (World Bank / market data still work).
FRED_API_KEY=
